# =============================================
# RAG 知识库系统 - Linux Docker 部署环境变量
# 使用说明：复制为 .env 后按实际情况修改
# cp .env.docker .env
# =============================================

# ==================== 项目根目录 ====================
PROJECT_ROOT=/app

# ==================== LLM（智谱 GLM）====================
LLM_DEFAULT_MODEL=glm-5.1
VL_MODEL=glm-4.6v
OPENAI_API_KEY=你的智谱API密钥
LLM_DEFAULT_TEMPERATURE=0.1
OPENAI_API_BASE=https://open.bigmodel.cn/api/paas/v4/

# ==================== Embedding 模型 ====================
# 模型通过 Docker volume 从宿主机 /opt/rag/models 挂载到 /app/models
BGE_M3_PATH=/app/models/BAAI/bge-m3
BGE_M3=BAAI/bge-m3
BGE_DEVICE=cpu
BGE_FP16=0

# ==================== Reranker 模型 ====================
BGE_RERANKER_LARGE=/app/models/BAAI/bge-reranker-large
BGE_RERANKER_DEVICE=cpu
BGE_RERANKER_FP16=0

# ==================== Milvus（外部部署）====================
MILVUS_URL=http://你的Milvus服务器IP:19530
CHUNKS_COLLECTION=kb_chunks
ITEM_NAME_COLLECTION=kb_item_names
ENTITY_NAME_COLLECTION=kb_graph_entity_names
EMBEDDING_DIM=1024

# ==================== MongoDB（外部部署）====================
MONGO_URL=mongodb://你的MongoDB服务器IP:27017
MONGO_DB_NAME=kb002

# ==================== MinIO（外部部署）====================
MINIO_ENDPOINT=你的MinIO服务器IP:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=knowledge-base-files
MINIO_IMG_DIR=/upload-images
MINIO_SECURE=False

# ==================== 日志 ====================
LOG_CONSOLE_ENABLE=True
LOG_CONSOLE_LEVEL=INFO
LOG_FILE_ENABLE=True
LOG_FILE_LEVEL=INFO
LOG_FILE_RETENTION=7 days
